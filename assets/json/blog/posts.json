---
layout: null
---
[
  {% assign all_docs = site.documents | where_exp: "doc", "doc.title" | sort: "date" | reverse %}
  {% for doc in all_docs %}
  {
    "title": {{ doc.title | jsonify }},
    "slug": {{ doc.slug | jsonify }},
    "url": {{ doc.url | jsonify }},
    "file": {{ doc.relative_path | jsonify }},
    "date": "{{ doc.date | date: '%Y-%m-%d' }}",
    "category": {{ doc.blog_section | default: doc.collection | replace: '_', '-' | jsonify }},
    {% if doc.platform %}"platform": {{ doc.platform | jsonify }},{% endif %}
    {% if doc.type %}"type": {{ doc.type | jsonify }},{% endif %}
    {% if doc.os %}"os": {{ doc.os | jsonify }},{% endif %}
    {% if doc.difficulty %}"difficulty": {{ doc.difficulty | jsonify }},{% endif %}
    {% if doc.link %}"link": {{ doc.link | jsonify }},{% endif %}
    "excerpt": {{ doc.summary | default: doc.excerpt | strip_html | strip_newlines | truncatewords: 30 | jsonify }},
    "tags": {{ doc.tags | default: empty | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]